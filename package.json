{
  "name": "plataforma-monitoramento-agentic",
  "version": "1.0.0",
  "description": "Plataforma Agentic de Monitoramento Superior - Monitoramento de redes sociais e mídia com agentes autônomos",
  "main": "dist/start.js",
  "types": "dist/start.d.ts",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm install && npm run build",
    "start": "node dist/start.js",
    "dev": "ts-node src/index.ts",
    "dev:server": "ts-node src/start.ts",
    "test": "jest --config jest.config.js",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "monitoramento",
    "redes-sociais",
    "agentes",
    "mcp",
    "lgpd"
  ],
  "author": "SETUR/CE",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "helmet": "^8.2.0",
    "node-fetch": "^2.7.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/node-fetch": "^2.6.9",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
