# Environment Variables
PORT=3000
NODE_ENV=development

# Encryption (AES-256)
ENCRYPTION_KEY=your-256-bit-encryption-key-change-in-production

# Logging
LOG_LEVEL=info
AUDIT_LOG_PATH=./logs/audit

# Vector Memory (In-memory for MVP, replace with Pinecone/Weaviate in production)
VECTOR_MEMORY_TYPE=memory

# MCP Configuration
MCP_SERVER_PORT=4000

# Social Media API Keys (configure as needed)
# TWITTER_BEARER_TOKEN=
# INSTAGRAM_ACCESS_TOKEN=
# LINKEDIN_ACCESS_TOKEN=
# TIKTOK_ACCESS_TOKEN=
